# Committed template. Copy to `.env` and adjust. `.env` itself is gitignored.
# These POSTGRES_* vars are read by BOTH docker-compose.yml (to create the DB)
# and later by config.py (so Python connects with the same credentials).

# --- Database (Postgres container) ---
POSTGRES_DB=ttc
POSTGRES_USER=ttc
POSTGRES_PASSWORD=ttc_dev_pw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
